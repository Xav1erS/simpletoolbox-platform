            </div>
            <div class="tab-content active" id="password-tab">
                <div class="input-section">
                <!-- 密码长度选项 -->
                <div class="option-group">
                    <h3>Password Length</h3>
                    <div class="slider-container">
                        <span class="slider-value" id="lengthValue">16</span>
                        <input type="range" class="slider" id="lengthSlider" min="4" max="64" value="16">
                        <span class="eye-icon" id="excludeSimilarEyeIcon" style="display: none; margin-left: 8px;" title="Excluding similar characters: 0/O, 1/l, I/i">
                            <i class="fas fa-eye" style="color: var(--primary-color); font-size: 1.2rem;"></i>
                        </span>
                    </div>
                </div>

                <!-- 字符类型选项 -->
                <div class="option-group">
                    <h3>Character Types</h3>
                    <div class="checkbox-group">
                        <label class="checkbox-item">
                            <input type="checkbox" id="uppercase" checked>
                            <span>Uppercase (A-Z)</span>
                        </label>
                        <label class="checkbox-item">
                            <input type="checkbox" id="lowercase" checked>
                            <span>Lowercase (a-z)</span>
                        </label>
                        <label class="checkbox-item">
                            <input type="checkbox" id="numbers" checked>
                            <span>Numbers (0-9)</span>
                        </label>
                        <label class="checkbox-item">
                            <input type="checkbox" id="symbols" checked>
                            <span>Symbols (!@#$%)</span>
                        </label>
                    </div>

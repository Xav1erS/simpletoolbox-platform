                    </button>
                </div>
            </div>
            
            <!-- API Keys 选项卡内容 -->
            <div class="tab-content" id="apikey-tab">
                <div class="input-section">
                    <!-- API 密钥长度选项 -->
                    <div class="option-group">
                        <h3>API Key Length</h3>
                        <div class="slider-container">
                            <span class="slider-value" id="keyLengthValue">32</span>
                            <input type="range" class="slider" id="keyLengthSlider" min="32" max="128" step="32" value="32">
                        </div>
                    </div>
                    
                    <!-- 字符类型选项 -->
                    <div class="option-group">
                        <h3>Character Type</h3>
                        <div class="checkbox-group">
                            <label class="checkbox-item">
                                <input type="radio" id="lettersOnly" name="charType" checked>
                                <span>Letters only (A-Z, a-z)</span>
                            </label>
                            <label class="checkbox-item">
                                <input type="radio" id="lettersNumbers" name="charType">
                                <span>Letters + Numbers (A-Z, a-z, 0-9)</span>
                            </label>
                        </div>
                    </div>
                    
                    <!-- 高级设置切换按钮 -->
                    <div style="text-align: center; margin: 1rem 0;">
                        <button class="toggle-advanced" id="toggleAdvanced">
                            <i class="fas fa-cog"></i> Advanced Settings
                        </button>
                    </div>
                    
                    <!-- 高级设置面板 -->
                    <div class="advanced-settings" id="advancedSettings">
                        <div class="prefix-suffix-input">
                            <div style="flex: 1;">
                                <label for="prefix">Prefix (optional)</label>
                                <input type="text" class="input-field" id="prefix" placeholder="e.g., sk_live_">
                            </div>
                            <div style="flex: 1;">
                                <label for="suffix">Suffix (optional)</label>
                                <input type="text" class="input-field" id="suffix" placeholder="e.g., _2024">
                            </div>

                    </div>
                    
                    <!-- 按钮组 -->
                    <div class="button-group">
                        <button class="btn btn-primary" id="generateApiKeyBtn">
                            <i class="fas fa-key"></i> Generate API Key
                        </button>
                        <button class="btn btn-secondary" id="clearApiKeyBtn">
                            <i class="fas fa-trash"></i> Clear
                        </button>
                    </div>

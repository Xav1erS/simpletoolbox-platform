                <!-- 自定义选项面板切换按钮 -->
                <div style="text-align: center; margin: 1rem 0;">
                    <button class="custom-options-toggle" id="customOptionsToggle">
                        <i class="fas fa-cog"></i> Advanced Options
                    </button>

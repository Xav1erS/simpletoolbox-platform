    <script>
        // 主题切换
        const themeToggle = document.getElementById('themeToggle');
        const themeIcon = themeToggle.querySelector('i');
        
        // 检查本地存储的主题偏好
        const savedTheme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', savedTheme);
        updateThemeIcon(savedTheme);
        
        themeToggle.addEventListener('click', () => {
            const currentTheme = document.documentElement.getAttribute('data-theme');
            const newTheme = currentTheme === 'light' ? 'dark' : 'light';
            
            document.documentElement.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            updateThemeIcon(newTheme);
        });
        
        function updateThemeIcon(theme) {
            themeIcon.className = theme === 'light' ? 'fas fa-moon' : 'fas fa-sun';
        }
        
        // 密码生成逻辑
        const generateBtn = document.getElementById('generateBtn');
        const clearBtn = document.getElementById('clearBtn');
        const lengthSlider = document.getElementById('lengthSlider');
        const lengthValue = document.getElementById('lengthValue');
        const uppercaseCheck = document.getElementById('uppercase');
        const lowercaseCheck = document.getElementById('lowercase');
        const numbersCheck = document.getElementById('numbers');
        const symbolsCheck = document.getElementById('symbols');
        const resultSection = document.getElementById('resultSection');
        const resultBox = document.getElementById('resultBox');
        const copyBtn = document.getElementById('copyBtn');
        const strengthFill = document.getElementById('strengthFill');
        const strengthLabel = document.getElementById('strengthLabel');
        
        // 字符集
        const charSets = {
            uppercase: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
            lowercase: 'abcdefghijklmnopqrstuvwxyz',
            numbers: '0123456789',
            symbols: '!@#$%^&*()_+-=[]{}|;:,.<>?'
        };
        
        // 更新滑块显示
        lengthSlider.addEventListener('input', () => {
            lengthValue.textContent = lengthSlider.value;
            updateStrengthIndicator();
        });
        
        // 复选框变化时更新强度
        [uppercaseCheck, lowercaseCheck, numbersCheck, symbolsCheck].forEach(checkbox => {
            checkbox.addEventListener('change', updateStrengthIndicator);
        });
        
        // 更新密码强度指示器
        function updateStrengthIndicator() {
            const length = parseInt(lengthSlider.value);
            let selectedSets = 0;
            if (uppercaseCheck.checked) selectedSets++;
            if (lowercaseCheck.checked) selectedSets++;
            if (numbersCheck.checked) selectedSets++;
            if (symbolsCheck.checked) selectedSets++;
            
            // 计算强度分数 (0-100)
            let score = 0;
            score += Math.min(length * 3, 30); // 长度贡献最大30分
            score += selectedSets * 15; // 每种字符类型贡献15分
            
            // 确保至少有一种字符类型被选中
            if (selectedSets === 0) score = 0;
            
            // 更新UI
            const width = Math.min(score, 100);
            strengthFill.style.width = `${width}%`;
            
            // 设置颜色和标签
            let strengthText, color;
            if (score >= 80) {
                strengthText = 'Very Strong';
                color = '#10b981'; // 绿色
            } else if (score >= 60) {
                strengthText = 'Strong';
                color = '#3b82f6'; // 蓝色
            } else if (score >= 40) {
                strengthText = 'Moderate';
                color = '#f59e0b'; // 黄色
            } else if (score >= 20) {
                strengthText = 'Weak';
                color = '#ef4444'; // 红色
            } else {
                strengthText = 'Very Weak';
                color = '#6b7280'; // 灰色
            }
            
            strengthFill.style.backgroundColor = color;
            strengthLabel.textContent = strengthText;
            strengthLabel.style.color = color;
        }
        
        // 初始化强度指示器
        updateStrengthIndicator();
        

        
        // 生成密码
        generateBtn.addEventListener('click', async () => {
            const generateBtnText = document.getElementById('generateBtnText');
            const generateBtnLoading = document.getElementById('generateBtnLoading');
            const generateBtnSuccess = document.getElementById('generateBtnSuccess');
            
            // 点击动画：添加clicked类
            generateBtn.classList.add('clicked');
            
            // 获取输入值
            const length = parseInt(lengthSlider.value);
            const excludeSimilarCheck = document.getElementById('excludeSimilar');
            const options = {
                uppercase: uppercaseCheck.checked,
                lowercase: lowercaseCheck.checked,
                numbers: numbersCheck.checked,
                symbols: symbolsCheck.checked,
                excludeSimilar: excludeSimilarCheck ? excludeSimilarCheck.checked : false
            };
            
            // 检查至少选择了一种字符类型
            const selectedTypes = Object.values(options).filter(v => v).length;
            if (selectedTypes === 0) {
                alert('Please select at least one character type.');
                generateBtn.classList.remove('clicked');
                return;
            }
            
            // 显示加载状态
            generateBtnText.style.display = 'none';
            generateBtnLoading.style.display = 'inline';
            generateBtnSuccess.style.display = 'none';
            generateBtn.disabled = true;
            
            // 移动端震动反馈
            if ('vibrate' in navigator) {
                navigator.vibrate(50);
            }
            
            // 模拟短暂延迟以显示加载状态（实际生成很快）
            await new Promise(resolve => setTimeout(resolve, 300));
            
            // 生成密码
            const password = generatePassword(length, options);
            
            // 显示成功状态：按钮文字变为Regenerate，添加绿色对勾图标
            generateBtnLoading.style.display = 'none';
            generateBtnSuccess.innerHTML = '<i class="fas fa-check" style="color: var(--success-color);"></i> Regenerate';
            generateBtnSuccess.style.display = 'inline';
            
            // 显示结果
            resultBox.textContent = password;
            resultSection.classList.add('active');
            
            // 滚动到结果区域
            resultSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            
            // 3秒后重置按钮状态，移除点击动画类
            setTimeout(() => {
                generateBtnSuccess.style.display = 'none';
                generateBtnText.style.display = 'inline';
                generateBtn.disabled = false;
                generateBtn.classList.remove('clicked');
            }, 3000);
            
            // 保存到历史记录
            saveToHistory(password);
        });
        
        // 密码生成算法
        function generatePassword(length, options) {
            // 构建可用字符集
            let availableChars = '';
            if (options.uppercase) availableChars += charSets.uppercase;
            if (options.lowercase) availableChars += charSets.lowercase;
            if (options.numbers) availableChars += charSets.numbers;
            if (options.symbols) availableChars += charSets.symbols;
            
            // 确保字符集非空
            if (availableChars.length === 0) {
                return 'Error: No character types selected';
            }
            
            // 如果启用排除相似字符，过滤字符集
            if (options.excludeSimilar) {
                availableChars = filterSimilarCharacters(availableChars);
                // 如果过滤后字符集为空，返回错误
                if (availableChars.length === 0) {
                    return 'Error: No characters left after excluding similar ones. Please select more character types.';
                }
            }
            
            // 使用cryptographically secure random
            const array = new Uint32Array(length);
            window.crypto.getRandomValues(array);
            
            let password = '';
            for (let i = 0; i < length; i++) {
                password += availableChars[array[i] % availableChars.length];
            }
            
            return password;
        }
        
        // 过滤相似字符函数
        function filterSimilarCharacters(chars) {
            // 相似字符映射：要排除的字符
            const similarMap = {
                '0': 'O', 'O': '0',
                '1': 'l', 'l': '1',
                'I': 'i', 'i': 'I',
                '|': 'I', 'I': '|',
                'S': '5', '5': 'S',
                'Z': '2', '2': 'Z'
            };
            
            // 过滤掉在similarMap中出现的字符
            return chars.split('').filter(char => {
                // 如果字符在映射中，并且映射到的字符也在字符集中，则排除
                const similarChar = similarMap[char];
                if (similarChar && chars.includes(similarChar)) {
                    // 保留其中一个，排除另一个（这里保留第一个出现的）
                    // 简单实现：排除数字和容易混淆的字母
                    return false;
                }
                return true;
            }).join('');
        }
        
        // 自定义选项面板切换
        const customOptionsToggle = document.getElementById('customOptionsToggle');
        const customOptionsPanel = document.getElementById('customOptionsPanel');
        
        if (customOptionsToggle && customOptionsPanel) {
            customOptionsToggle.addEventListener('click', () => {
                customOptionsPanel.classList.toggle('active');
                const icon = customOptionsToggle.querySelector('i');
                if (customOptionsPanel.classList.contains('active')) {
                    icon.className = 'fas fa-times';
                    customOptionsToggle.innerHTML = '<i class="fas fa-times"></i> Hide Advanced Options';
                } else {
                    icon.className = 'fas fa-cog';
                    customOptionsToggle.innerHTML = '<i class="fas fa-cog"></i> Advanced Options';
                }
            });
        }
        
        // 眼睛图标提示功能
        const excludeSimilarCheckbox = document.getElementById('excludeSimilar');
        const eyeIconElement = document.getElementById('excludeSimilarEyeIcon');
        
        if (excludeSimilarCheckbox && eyeIconElement) {
            // 初始状态
            eyeIconElement.style.display = excludeSimilarCheckbox.checked ? 'inline-flex' : 'none';
            
            // 监听复选框变化
            excludeSimilarCheckbox.addEventListener('change', () => {
                eyeIconElement.style.display = excludeSimilarCheckbox.checked ? 'inline-flex' : 'none';
            });
        }
        
        // 清空功能
        clearBtn.addEventListener('click', () => {
            resultSection.classList.remove('active');
            resultBox.textContent = 'Click "Generate Password" to create a secure password.';
            lengthSlider.value = 16;
            lengthValue.textContent = '16';
            uppercaseCheck.checked = true;
            lowercaseCheck.checked = true;
            numbersCheck.checked = true;
            symbolsCheck.checked = true;
            // 重置自定义选项
            const excludeSimilarCheck = document.getElementById('excludeSimilar');
            if (excludeSimilarCheck) {
                excludeSimilarCheck.checked = false;
            }
            // 隐藏自定义选项面板
            if (customOptionsPanel) {
                customOptionsPanel.classList.remove('active');
                if (customOptionsToggle) {
                    customOptionsToggle.innerHTML = '<i class="fas fa-cog"></i> Advanced Options';
                }
            }
            updateStrengthIndicator();
        });
        
        // 复制功能
        copyBtn.addEventListener('click', async () => {
            const password = resultBox.textContent;
            if (!password || password.includes('Click "Generate Password"')) {
                alert('No password to copy. Please generate a password first.');
                return;
            }
            
            try {
                await navigator.clipboard.writeText(password);
                const originalText = copyBtn.innerHTML;
                copyBtn.innerHTML = '<i class="fas fa-check"></i> Copied!';
                
                setTimeout(() => {
                    copyBtn.innerHTML = originalText;
                }, 2000);
            } catch (err) {
                console.error('Failed to copy: ', err);
                alert('Failed to copy password to clipboard.');
            }
        });
        
        // 设置当前年份
        document.getElementById('currentYear').textContent = new Date().getFullYear();
        
        // 页面加载时自动聚焦生成按钮
        window.addEventListener('load', () => {
            generateBtn.focus();
            
            // 隐藏页面加载动画
            const loadingOverlay = document.getElementById('pageLoadingOverlay');
            if (loadingOverlay) {
                loadingOverlay.style.opacity = '0';
                setTimeout(() => {
                    loadingOverlay.style.display = 'none';
                }, 300);
            }
        });
        
        // 键盘快捷键
        document.addEventListener('keydown', (e) => {
            // Ctrl/Cmd + G 生成密码
            if ((e.ctrlKey || e.metaKey) && e.key === 'g') {
                e.preventDefault();
                generateBtn.click();
            }
            
            // Esc 清空
            if (e.key === 'Escape') {
                clearBtn.click();
            }
        });
        
        // Google AdSense初始化（示例）
        function initAdSense() {
            // 这里添加实际的AdSense初始化代码
            console.log('AdSense initialized (placeholder)');
        }
        
        // 初始化广告
        if (typeof adsbygoogle !== 'undefined') {
            initAdSense();
        }
    
        // 处理 About, Terms, Privacy 页面显示
        document.addEventListener('DOMContentLoaded', function() {
            // 获取所有页脚链接
            const links = document.querySelectorAll('.footer-links a');
            links.forEach(link => {
                link.addEventListener('click', function(e) {
                    const href = this.getAttribute('href');
                    if (href.startsWith('#')) {
                        e.preventDefault();
                        const targetId = href.substring(1);
                        const targetSection = document.getElementById(targetId);
                        if (targetSection) {
                            // 隐藏所有其他页面
                            document.querySelectorAll('[id="about"],[id="terms"],[id="privacy"]').forEach(sec => {
                                sec.style.display = 'none';
                            });
                            // 显示目标页面
                            targetSection.style.display = 'block';
                            // 滚动到目标
                            targetSection.scrollIntoView({ behavior: 'smooth' });
                        }
                    }
                });
            });
        });
        
        // 历史记录功能
        function saveToHistory(password) {
            try {
                let history = JSON.parse(localStorage.getItem('passwordHistory') || '[]');
                // 添加新记录到开头
                history.unshift({
                    password: password,
                    timestamp: new Date().toISOString(),
                    date: new Date().toLocaleString()
                });
                // 只保留最近10条记录
                history = history.slice(0, 10);
                localStorage.setItem('passwordHistory', JSON.stringify(history));
                // 刷新历史记录显示
                renderHistory();
            } catch (error) {
                console.error('Failed to save to history:', error);
            }
        }
        
        function renderHistory() {
            const historyList = document.getElementById('historyList');
            const historyEmpty = document.getElementById('historyEmpty');
            
            if (!historyList) return;
            
            try {
                const history = JSON.parse(localStorage.getItem('passwordHistory') || '[]');
                
                if (history.length === 0) {
                    historyList.innerHTML = '';
                    if (historyEmpty) historyEmpty.style.display = 'block';
                    return;
                }
                
                if (historyEmpty) historyEmpty.style.display = 'none';
                
                let html = '';
                history.forEach((item, index) => {
                    html += `
                    <li class="history-item">
                        ${item.password}
                        <div class="history-item-actions">
                            <button class="history-copy-btn" onclick="copyHistoryPassword('${item.password.replace(/'/g, "\\'")}')">
                                <i class="fas fa-copy"></i> Copy
                            </button>
                            <button class="history-delete-btn" onclick="deleteHistoryItem(${index})">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </div>
                    </li>
                    `;
                });
                
                historyList.innerHTML = html;
            } catch (error) {
                console.error('Failed to render history:', error);
                if (historyEmpty) historyEmpty.style.display = 'block';
            }
        }
        
        function copyHistoryPassword(password) {
            navigator.clipboard.writeText(password).then(() => {
                alert('Password copied to clipboard!');
            }).catch(err => {
                console.error('Failed to copy:', err);
                alert('Failed to copy password.');
            });
        }
        
        function deleteHistoryItem(index) {
            try {
                let history = JSON.parse(localStorage.getItem('passwordHistory') || '[]');
                history.splice(index, 1);
                localStorage.setItem('passwordHistory', JSON.stringify(history));
                renderHistory();
            } catch (error) {
                console.error('Failed to delete history item:', error);
            }
        }
        
        function clearHistory() {
            if (confirm('Are you sure you want to clear all history?')) {
                localStorage.removeItem('passwordHistory');
                renderHistory();
            }
        }
        
        // 初始化历史记录显示
        document.addEventListener('DOMContentLoaded', function() {
            renderHistory();
        });
    </script>
    
    <!-- 历史记录面板 HTML -->
    <button class="history-toggle-btn" id="historyToggleBtn" aria-label="Open history panel">
        <i class="fas fa-history"></i> History
    </button>
    
    <div class="history-panel" id="historyPanel">
        <div class="history-header">
            <h3>Password History</h3>
            <button class="history-close" id="historyCloseBtn" aria-label="Close history panel">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="history-content">
            <ul class="history-list" id="historyList">
                <!-- 历史记录将通过JavaScript动态插入 -->
            </ul>
            <div class="history-empty" id="historyEmpty" style="display: none;">
                <p>No passwords generated yet.</p>
                <p>Generate a password to see it here.</p>
            </div>
        </div>
        <div style="padding: 1rem; border-top: 1px solid var(--border-color); text-align: center;">
            <button onclick="clearHistory()" style="background: none; border: none; color: var(--text-light); cursor: pointer; font-size: 0.9rem;">
                <i class="fas fa-trash-alt"></i> Clear All History
            </button>
        </div>
    </div>
    
    <script>
        // 历史记录面板切换
        const historyToggleBtn = document.getElementById('historyToggleBtn');
        const historyCloseBtn = document.getElementById('historyCloseBtn');
        const historyPanel = document.getElementById('historyPanel');
        
        if (historyToggleBtn && historyPanel) {
            historyToggleBtn.addEventListener('click', () => {
                historyPanel.classList.add('active');
                historyToggleBtn.style.display = 'none';
            });
            
            historyCloseBtn.addEventListener('click', () => {
                historyPanel.classList.remove('active');
                setTimeout(() => {
                    historyToggleBtn.style.display = 'flex';
                }, 300);
            });
            
            // 点击面板外部关闭
            document.addEventListener('click', (event) => {
                if (historyPanel.classList.contains('active') && 
                    !historyPanel.contains(event.target) && 
                    event.target !== historyToggleBtn) {
                    historyPanel.classList.remove('active');
                    setTimeout(() => {
                        historyToggleBtn.style.display = 'flex';
                    }, 300);
                }
            });
        }
    </script>
<script>
// 选项卡切换功能（修复版本）
document.addEventListener('DOMContentLoaded', function() {
    // 标签页切换功能
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');
    console.log('Tab切换脚本加载，找到按钮:', tabBtns.length);
    
    tabBtns.forEach(btn => {
        btn.addEventListener('click', function() {
            const tabId = this.getAttribute('data-tab');
            console.log('选项卡点击:', tabId);
            
            // 更新活动按钮
            tabBtns.forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            
            // 显示对应内容
            tabContents.forEach(content => {
                content.classList.remove('active');
                if (content.id === tabId + '-tab') {
                    content.classList.add('active');
                }
            });
            
            // 隐藏结果区域（如果可见）
            const resultSection = document.getElementById('resultSection');
            const apiKeyResultSection = document.getElementById('apiKeyResultSection');
            if (resultSection) resultSection.classList.remove('active');
            if (apiKeyResultSection) apiKeyResultSection.style.display = 'none';
        });
    });
    
    // 初始化标签页状态
    window.addEventListener('load', function() {
        const passwordTab = document.getElementById('password-tab');
        const apiKeyTab = document.getElementById('apikey-tab');
        if (passwordTab) passwordTab.classList.add('active');
        if (apiKeyTab) apiKeyTab.classList.remove('active');
    });
});
</script>
</body>
</html>
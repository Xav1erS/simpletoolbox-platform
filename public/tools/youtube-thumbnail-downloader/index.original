    <!-- 历史记录悬浮栏 -->
    <div class="history-widget">
        <button class="history-toggle" id="historyToggle" aria-label="Show history">
            <i class="fas fa-history"></i>
        </button>
        <div class="history-panel" id="historyPanel">
            <div class="history-header">
                <h3>Recent Downloads</h3>
                <button class="clear-history" id="clearHistory">Clear All</button>
            </div>
            <div class="history-list" id="historyList">
                <!-- 历史记录将通过JS动态生成 -->
            </div>
        </div>
    </div>

    <!-- 页脚 -->
    <footer>
        <div class="footer-container">
            <div class="footer-links">
                <a href="/privacy">Privacy Policy</a>
                <a href="/terms">Terms of Service</a>
                <a href="/contact">Contact</a>
                <a href="/about">About</a>
                <a href="/feedback">Feedback</a>
            </div>
            <p>Free YouTube Thumbnail Downloader</p>
        </div>
    </footer>

    <script>
        // 主题切换
        const themeToggle = document.getElementById('themeToggle');
        const themeIcon = themeToggle.querySelector('i');
        
        // 检查本地存储的主题偏好
        const savedTheme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', savedTheme);
        updateThemeIcon(savedTheme);
        
        themeToggle.addEventListener('click', () => {
            const currentTheme = document.documentElement.getAttribute('data-theme');
            const newTheme = currentTheme === 'light' ? 'dark' : 'light';
            
            document.documentElement.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            updateThemeIcon(newTheme);
        });
        
        function updateThemeIcon(theme) {
            themeIcon.className = theme === 'light' ? 'fas fa-moon' : 'fas fa-sun';
        }
        
        // 工具逻辑
        const processBtn = document.getElementById('processBtn');
        const clearBtn = document.getElementById('clearBtn');
        const videoUrlInput = document.getElementById('videoUrl');
        const resultSection = document.getElementById('resultSection');
        const videoIdDisplay = document.getElementById('videoIdDisplay');
        const extractedVideoId = document.getElementById('extractedVideoId');
        const thumbnailsGrid = document.getElementById('thumbnailsGrid');
        const errorMessage = document.getElementById('errorMessage');
        const errorText = document.getElementById('errorText');
        
        // 错误处理函数
        function showError(message) {
            errorText.textContent = message;
            errorMessage.classList.add('active');
            videoUrlInput.style.borderColor = 'var(--error-color)';
            // 自动隐藏错误消息（5秒后）
            setTimeout(hideError, 5000);
        }
        
        function hideError() {
            errorMessage.classList.remove('active');
            videoUrlInput.style.borderColor = '';
        }
        
        // 清空错误消息当用户开始输入时
        videoUrlInput.addEventListener('input', hideError);
        
        // 提取YouTube视频ID的函数
        function extractYouTubeVideoId(url) {
            // 处理各种YouTube URL格式
            const patterns = [
                /(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/|youtube\.com\/shorts\/)([a-zA-Z0-9_-]{11})/,
                /^([a-zA-Z0-9_-]{11})$/
            ];
            
            for (const pattern of patterns) {
                const match = url.match(pattern);
                if (match && match[1]) {
                    return match[1];
                }
            }
            
            return null;
        }
        
        // 生成缩略图URL
        function generateThumbnailUrls(videoId) {
            return [
                {
                    name: 'Max Resolution',
                    size: 'maxresdefault',
                    url: `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`,
                    dimensions: '1280×720',
                    description: 'Highest quality thumbnail (1280x720)'
                },
                {
                    name: 'High Quality',
                    size: 'hqdefault',
                    url: `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`,
                    dimensions: '480×360',
                    description: 'High quality thumbnail (480x360)'
                },
                {
                    name: 'Standard Definition',
                    size: 'sddefault',
                    url: `https://img.youtube.com/vi/${videoId}/sddefault.jpg`,
                    dimensions: '640×480',
                    description: 'Standard definition thumbnail (640x480)'
                },
                {
                    name: 'Default',
                    size: 'default',
                    url: `https://img.youtube.com/vi/${videoId}/default.jpg`,
                    dimensions: '120×90',
                    description: 'Default thumbnail (120x90)'
                },
                {
                    name: 'Medium Quality',
                    size: 'mqdefault',
                    url: `https://img.youtube.com/vi/${videoId}/mqdefault.jpg`,
                    dimensions: '320×180',
                    description: 'Medium quality thumbnail (320x180)'
                }
            ];
        }
        
        // 创建缩略图卡片
        function createThumbnailCard(thumbnail) {
            const card = document.createElement('div');
            card.className = 'thumbnail-card';
            
            card.innerHTML = `
                <div class="thumbnail-size">${thumbnail.name}</div>
                <div class="thumbnail-dimensions">${thumbnail.dimensions} (${thumbnail.size})</div>
                <img src="${thumbnail.url}" alt="${thumbnail.name}" class="thumbnail-preview" loading="lazy">
                <p>${thumbnail.description}</p>
                <a href="${thumbnail.url}" target="_blank" class="download-link" download="youtube-thumbnail-${thumbnail.size}.jpg">
                    <i class="fas fa-download"></i> Download
                </a>
            `;
            
            return card;
        }
        
        // 历史记录功能
        const HISTORY_KEY = 'youtube_thumbnail_history';
        const MAX_HISTORY = 5;
        
        function saveToHistory(videoId) {
            let history = JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]');
            // 移除重复项（如果已存在）
            history = history.filter(item => item.id !== videoId);
            // 添加新项到开头
            history.unshift({
                id: videoId,
                timestamp: new Date().toISOString()
            });
            // 限制数量
            if (history.length > MAX_HISTORY) {
                history = history.slice(0, MAX_HISTORY);
            }
            localStorage.setItem(HISTORY_KEY, JSON.stringify(history));
            loadHistory();
        }
        
        function loadHistory() {
            const history = JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]');
            const historyList = document.getElementById('historyList');
            if (!historyList) return;
            
            if (history.length === 0) {
                historyList.innerHTML = '<div class="history-empty">No recent downloads</div>';
                return;
            }
            
            const items = history.map(item => {
                const date = new Date(item.timestamp);
                const timeString = date.toLocaleDateString() + ' ' + date.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                return `
                    <div class="history-item" data-video-id="${item.id}">
                        <div class="video-id">${item.id}</div>
                        <div class="timestamp">${timeString}</div>
                    </div>
                `;
            }).join('');
            
            historyList.innerHTML = items;
            
            // 为每个历史记录项添加点击事件
            document.querySelectorAll('.history-item').forEach(item => {
                item.addEventListener('click', function() {
                    const videoId = this.getAttribute('data-video-id');
                    videoUrlInput.value = `https://www.youtube.com/watch?v=${videoId}`;
                    processBtn.click();
                });
            });
        }
        
        function clearHistory() {
            localStorage.removeItem(HISTORY_KEY);
            loadHistory();
        }
        
        // 历史记录悬浮栏交互
        const historyToggle = document.getElementById('historyToggle');
        const historyPanel = document.getElementById('historyPanel');
        const clearHistoryBtn = document.getElementById('clearHistory');
        
        if (historyToggle && historyPanel) {
            historyToggle.addEventListener('click', () => {
                historyPanel.classList.toggle('active');
            });
        }
        
        if (clearHistoryBtn) {
            clearHistoryBtn.addEventListener('click', clearHistory);
        }
        
        // 页面加载时加载历史记录
        document.addEventListener('DOMContentLoaded', loadHistory);
        if (document.readyState !== 'loading') {
            loadHistory();
        }
        
        // 一键下载HD缩略图功能
        document.addEventListener('DOMContentLoaded', function() {
            const hdDownloadBtn = document.getElementById('hdDownloadBtn');
            if (hdDownloadBtn) {
                hdDownloadBtn.addEventListener('click', function() {
                    const videoId = document.getElementById('extractedVideoId').textContent;
                    if (videoId) {
                        const hdUrl = `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`;
                        window.open(hdUrl, '_blank');
                    } else {
                        showError('No video ID found. Please process a YouTube URL first.');
                    }
                });
            }
        });
        
        // 处理按钮点击事件
        processBtn.addEventListener('click', () => {
            // 添加加载状态
            processBtn.classList.add('loading');
            processBtn.disabled = true;
            processBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
            
            const url = videoUrlInput.value.trim();
            
            if (!url) {
                // 移除加载状态
                processBtn.classList.remove('loading');
                processBtn.disabled = false;
                processBtn.innerHTML = '<i class="fas fa-download"></i> Get Thumbnails';
                showError('Please enter a YouTube URL or video ID.');
                return;
            }
            
            const videoId = extractYouTubeVideoId(url);
            
            if (!videoId) {
                // 移除加载状态
                processBtn.classList.remove('loading');
                processBtn.disabled = false;
                processBtn.innerHTML = '<i class="fas fa-download"></i> Get Thumbnails';
                showError('Invalid YouTube URL or video ID. Please check your input.');
                return;
            }
            
            // 显示视频ID
            videoIdDisplay.textContent = videoId;
            extractedVideoId.textContent = videoId;
            
            // 生成缩略图
            const thumbnails = generateThumbnailUrls(videoId);
            
            // 清空网格
            thumbnailsGrid.innerHTML = '';
            
            // 添加缩略图卡片
            thumbnails.forEach(thumbnail => {
                const card = createThumbnailCard(thumbnail);
                thumbnailsGrid.appendChild(card);
            });
            
            // 显示结果区域
            resultSection.classList.add('active');
            
            // 滚动到结果区域
            resultSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            
            // 保存到历史记录
            saveToHistory(videoId);
            
            // 恢复按钮状态
            processBtn.classList.remove('loading');
            processBtn.disabled = false;
            processBtn.innerHTML = '<i class="fas fa-download"></i> Get Thumbnails';
        });
        
        // 清空按钮点击事件
        clearBtn.addEventListener('click', () => {
            videoUrlInput.value = '';
            resultSection.classList.remove('active');
            thumbnailsGrid.innerHTML = '';
            videoUrlInput.focus();
        });
        
        // 设置当前年份
        document.getElementById('currentYear').textContent = new Date().getFullYear();
        
        // 页面加载时自动聚焦输入框
        window.addEventListener('load', () => {
            videoUrlInput.focus();
        });
        
        // 键盘快捷键
        document.addEventListener('keydown', (e) => {
            // Ctrl/Cmd + Enter 处理
            if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
                e.preventDefault();
                processBtn.click();
            }
            
            // Esc 清空
            if (e.key === 'Escape') {
                clearBtn.click();
            }
        });
        
        // Google AdSense初始化（示例）
        function initAdSense() {
            // 这里添加实际的AdSense初始化代码
            console.log('AdSense initialized (placeholder)');
            // 示例代码：实际使用时需要替换为真实的发布商ID
            // (adsbygoogle = window.adsbygoogle || []).push({});
        }
        
        // 初始化广告
        if (typeof adsbygoogle !== 'undefined') {
            initAdSense();
        }

        // 关闭广告功能
        function setupAdCloseButtons() {
            document.querySelectorAll('.close-ad-button').forEach(button => {
                button.addEventListener('click', function() {
                    const adContainer = this.closest('.ad-container');
                    if (adContainer) {
                        adContainer.style.display = 'none';
                        // 可选：保存用户偏好到localStorage
                        localStorage.setItem('ad-closed', 'true');
                    }
                });
            });
        }

        // 页面加载后初始化关闭按钮
        document.addEventListener('DOMContentLoaded', setupAdCloseButtons);
        // 如果DOM已经加载，立即执行
        if (document.readyState !== 'loading') {
            setupAdCloseButtons();
        }
    </script>
</body>
</html>
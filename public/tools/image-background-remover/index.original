    <!-- Timeout Retry Modal -->
    <div class="timeout-modal" id="timeoutModal">
        <div class="timeout-modal-content">
            <h4 class="fw-bold mb-3">Processing Timeout</h4>
            <p class="text-muted mb-4">The background removal is taking longer than expected. Would you like to retry with a smaller image or try again?</p>
            <div class="d-flex gap-3">
                <button class="btn btn-primary flex-grow-1" onclick="retryProcessing()">
                    <i class="fas fa-redo me-2"></i>Retry
                </button>
                <button class="btn btn-outline-secondary flex-grow-1" onclick="closeTimeoutModal()">
                    <i class="fas fa-times me-2"></i>Cancel
                </button>
            </div>
        </div>
    </div>

